{
  "manifest_version": 3,
  "name": "TruthLens Quick Check",
  "description": "Send highlighted claims from any webpage to TruthLens.",
  "version": "0.1.0",
  "permissions": ["contextMenus", "activeTab"],
  "host_permissions": ["http://127.0.0.1:5173/*", "http://localhost:5173/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TruthLens",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
